# ── LLM ─────────────────────────────────────────────────────────────────────
# 切换模型只改这两行，支持 OpenAI / DeepSeek / 通义千问 / 任何 OpenAI 兼容接口
LLM_MODEL=gpt-4o
LLM_API_KEY=sk-xxx

# 如果用 OpenAI 兼容接口（如 DeepSeek），填写 base_url；OpenAI 官方留空
# DeepSeek 示例: https://api.deepseek.com
# 通义千问示例: https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_BASE_URL=

# Embedding 模型（用于 RAG 向量化）
EMBEDDING_MODEL=text-embedding-3-small

# RAG provider: qdrant | volcengine_kb
RAG_PROVIDER=qdrant

# ── 基础设施（对话历史存 MongoDB，本地开发可先 docker compose -f docker-compose.dev.yml up -d） ──
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=knowledge_base

# 火山引擎知识库（启用时将 RAG_PROVIDER 改为 volcengine_kb）
VOLC_KB_SCHEME=https
VOLC_KB_HOST=api-knowledgebase.mlp.cn-beijing.volces.com
VOLC_KB_REGION=cn-north-1
VOLC_KB_SERVICE=air
VOLC_KB_AK=
VOLC_KB_SK=
VOLC_KB_ACCOUNT_ID=
VOLC_KB_PROJECT=default
VOLC_KB_COLLECTION_NAME=
VOLC_KB_RESOURCE_ID=
VOLC_KB_LIMIT=5
VOLC_KB_RETRIEVE_COUNT=10
VOLC_KB_DENSE_WEIGHT=0.5
VOLC_KB_RERANK_SWITCH=true
VOLC_KB_CHUNK_GROUP=true
VOLC_KB_RERANK_ONLY_CHUNK=false
VOLC_KB_CHUNK_DIFFUSION_COUNT=0
VOLC_KB_TIMEOUT_SECONDS=30

MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=ai_customer

# ── 应用 ──────────────────────────────────────────────────────────────────────
# 通知产研团队的接口（吐槽/售后意图会调用）
NOTIFY_API_URL=http://your-admin-backend/api/notify
NOTIFY_API_KEY=

# 前端跨域（多个用逗号分隔）
CORS_ORIGINS=http://localhost:5173
