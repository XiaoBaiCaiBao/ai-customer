# ── LLM ─────────────────────────────────────────────────────────────────────
# 切换模型只改这两行，支持 OpenAI / DeepSeek / 通义千问 / 任何 OpenAI 兼容接口
LLM_MODEL=gpt-4o
LLM_API_KEY=sk-xxx

# 如果用 OpenAI 兼容接口（如 DeepSeek），填写 base_url；OpenAI 官方留空
# DeepSeek 示例: https://api.deepseek.com
# 通义千问示例: https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_BASE_URL=

# Embedding 模型（用于 RAG 向量化）
EMBEDDING_MODEL=text-embedding-3-small

# ── 存储模式 ──────────────────────────────────────────────────────────────────
# true=内存（本地开发，无需 Docker）  false=MongoDB（生产部署）
USE_MEMORY=true

# ── 基础设施（USE_MEMORY=false 时才需要填） ────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=knowledge_base

MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=ai_customer

# ── 应用 ──────────────────────────────────────────────────────────────────────
# 通知产研团队的接口（吐槽/售后意图会调用）
NOTIFY_API_URL=http://your-admin-backend/api/notify
NOTIFY_API_KEY=

# 前端跨域（多个用逗号分隔）
CORS_ORIGINS=http://localhost:5173
